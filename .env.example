# Sigil environment template. Copy to .env.local and fill in.
# Never commit real secrets. AGENT_PRIVATE_KEY is server only.

# --- Tatum (all Sui RPC goes through Tatum) ---
TATUM_API_KEY=

# --- Sui network selection ---
# testnet during development, mainnet for production
SUI_NETWORK=testnet
# Testnet:  https://sui-testnet.gateway.tatum.io
# Mainnet:  https://sui-mainnet.gateway.tatum.io
SUI_RPC_URL=https://sui-testnet.gateway.tatum.io

# --- Walrus over HTTP (public publisher + aggregator) ---
# Current public endpoints are listed at docs.wal.app
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# --- Sigil Move package (filled after publishing the Move package) ---
SIGIL_PACKAGE_ID=
# Exposed to the browser for the human wallet flow
NEXT_PUBLIC_SIGIL_PACKAGE_ID=
NEXT_PUBLIC_SUI_NETWORK=testnet

# --- Agent flow (server only) ---
# Dedicated agent keypair, separate from the deployer. Generated locally,
# bech32 suiprivkey1... Never commit the real value.
AGENT_PRIVATE_KEY=
# API key an agent presents (x-api-key or Authorization: Bearer) to /api/sign.
# Maps to the single AGENT_PRIVATE_KEY address in this build.
AGENT_API_KEY=
# Deployer key, used by publish + create scripts (server only).
DEPLOYER_PRIVATE_KEY=
# Sui private key for the server side agent signer (suiprivkey... bech32)
AGENT_PRIVATE_KEY=
# Comma separated list of agent API keys, or a JSON map
AGENT_API_KEYS=
